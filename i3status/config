general {
    interval = 1
    colors = false
}

order += "wireless_first_"
order += "ethernet _first_"
order += "memory"
order += "disk /"
order += "tztime local"

wireless _first_ {
    format_up = "%essid"
    format_down = "down"
}

ethernet _first_ {
    format_up = "%ip"
    format_down = "down"
}

memory {
    format = "RAM: %used / %total"
}

disk "/" {
    format = "Disk: %used (%percentage_used)"
}

tztime local {
    format = "%d-%m-%Y %H:%M:%S"
}
